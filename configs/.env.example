# Copy to configs/.env and fill in local values. Do not commit real credentials.
# Runtime profiles are defined in configs/llm_profiles.yaml.example.

# Main pipeline chat LLM profiles.
PRIMARY_LLM_MODEL=qwen3-max
PRIMARY_LLM_BASE_URL=
PRIMARY_LLM_API_KEY=
SECONDARY_LLM_MODEL=deepseek-r1-0528
SECONDARY_LLM_BASE_URL=
SECONDARY_LLM_API_KEY=

# Optional evaluation judge profiles.
A_KIMI_MODEL=kimi-k2.5
A_KIMI_BASE_URL=
A_KIMI_API_KEY=
B_CLAUDE_MODEL=claude-opus-4-6
B_CLAUDE_BASE_URL=
B_CLAUDE_API_KEY=
C_GEMINI_MODEL=gemini-pro
C_GEMINI_BASE_URL=
C_GEMINI_API_KEY=

# Embedding service profile.
EMBED_MODEL_NAME=text-embedding-v4
EMBED_MODEL_BASE_URL=
EMBED_MODEL_API_KEY=

# Reranking service profile.
RERANK_MODEL_NAME=gte-rerank-v2
RERANK_API_ENDPOINT=
RERANK_BASE_URL=
RERANK_API_KEY=

# Optional profile file override.
LLM_PROFILES_CONFIG=
